{
  "_meta": {
    "description": "Single source of truth for state-specific residential building codes. Resolved per-claim by the property address's state. Loaded by building_codes/lookup.py. Adding a new state = add one row here, no code changes elsewhere.",
    "schema_version": 1,
    "default_fallback_key": "IRC",
    "note": "States without a state-adopted code that diverges meaningfully from IRC get the IRC default row. Enrich any state's row as needed — the lookup module merges over the default."
  },
